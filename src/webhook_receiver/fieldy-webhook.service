[Unit]
Description=Fieldy webhook capture receiver
After=network-online.target zfs-mount.service
Wants=network-online.target

[Service]
User=mike
EnvironmentFile=/opt/fieldy-webhook/env
ExecStart=/usr/bin/python3 /opt/fieldy-webhook/receiver.py
Restart=on-failure
RestartSec=3

[Install]
WantedBy=multi-user.target
